{
       "$schema": "https://www.getbifrost.ai/schema",
       "providers": {
              "github-models": {
                     "keys": [
                            {
                                   "name": "github-models",
                                   "value": "env.GITHUB_TOKEN",
                                   "models": [
                                          "*"
                                   ],
                                   "weight": 1.0
                            }
                     ],
                     "network_config": {
                            "base_url": "https://models.github.ai/inference"
                     },
                     "custom_provider_config": {
                            "base_provider_type": "openai",
                            "allowed_requests": {
                                   "chat_completion": true,
                                   "chat_completion_stream": true
                            }
                     }
              }
       }
}
